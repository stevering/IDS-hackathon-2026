{
  "name": "@guardian/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv-run -- sh -c 'export MCP_TUNNEL_SECRET=$(openssl rand -base64 32) && export NEXT_PUBLIC_MCP_TUNNEL_SECRET=$MCP_TUNNEL_SECRET && next dev'",
    "dev:proxy": "dotenv-run -- node scripts/dev-proxy.mjs",
    "build": "dotenv-run -- next build",
    "start": "dotenv-run -- next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.50",
    "@ai-sdk/gateway": "^3.0.59",
    "@ai-sdk/google": "^3.0.34",
    "@ai-sdk/mcp": "^1.0.19",
    "@ai-sdk/openai": "^3.0.37",
    "@ai-sdk/react": "^3.0.79",
    "@ai-sdk/xai": "^3.0.54",
    "@guardian/mcp-server": "workspace:*",
    "@guardian/orchestrations": "workspace:*",
    "@guardian/temporal": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/speed-insights": "^1.3.1",
    "ai": "^6.0.82",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
