STORAGE_POSTGRES_HOST="db.ID_DB.supabase.co"
STORAGE_POSTGRES_PASSWORD="DB_PASSWORD"
STORAGE_POSTGRES_PRISMA_URL="postgres://postgres.ID_DB:DB_PASSWORD@aws-1-eu-west-3.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
STORAGE_POSTGRES_URL="postgres://postgres.ID_DB:DB_PASSWORD@aws-1-eu-west-3.pooler.supabase.com:6543/postgres?sslmode=require&supa=base-pooler.x"
STORAGE_POSTGRES_URL_NON_POOLING="postgres://postgres.ID_DB:DB_PASSWORD@aws-1-eu-west-3.pooler.supabase.com:5432/postgres?sslmode=require"
STORAGE_POSTGRES_USER="postgres"
STORAGE_SUPABASE_ANON_KEY="AAA.BBB.CCC"
STORAGE_SUPABASE_JWT_SECRET="JWT_SECRET"
STORAGE_SUPABASE_PUBLISHABLE_KEY="PUBLISH_KEY"
STORAGE_SUPABASE_SECRET_KEY="SECRET_KEY"
STORAGE_SUPABASE_SERVICE_ROLE_KEY="AAA.KEY1.KEY2"
