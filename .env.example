XAI_API_KEY=XAI_API_KEY
MCP_TUNNEL_SECRET=YOUR_PRIVATE_SECRET

# Figma APP used for OAuth credentials (create one in https://www.figma.com/developers/apps)
# Make sure to add the redirect URL: http://127.0.0.1:3000/api/auth/figma-mcp/callback
FIGMA_CLIENT_ID=FIGMA_CLIENT_ID
FIGMA_CLIENT_SECRET=FIGMA_CLIENT_SECRET

NEXT_PUBLIC_BASE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_LOCAL_MCP_FIGMA_URL=http://127.0.0.1:3845/mcp
NEXT_PUBLIC_LOCAL_MCP_CODE_URL=http://127.0.0.1:3846/mcp
GUARDIAN_MCP_URL=http://127.0.0.1:3847/mcp
# Set to "true" to skip JWT verification on Guardian MCP in dev (avoids needing RS256 keys locally)
GUARDIAN_MCP_SKIP_AUTH=true
NEXT_PUBLIC_PROXY_LOCAL_FIGMA_MCP=http://localhost:3000/proxy-local/figma/mcp
NEXT_PUBLIC_PROXY_LOCAL_CODE_MCP=http://localhost:3000/proxy-local/code/mcp
# Southleft Figma Console
SOUTHLEFT_MCP_RESOURCE=https://figma-console-mcp.southleft.com/mcp

# Figma APP used for Oauth credentials (create one in https://github.com/settings/apps)
# Make sure to add the redirect Url: http://127.0.0.1:3000/api/auth/figma-mcp/callback
GITHUB_CLIENT_ID=GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=GITHUB_CLIENT_SECRET

# Supabase — server-only (never exposed to client)
SUPABASE_SERVICE_ROLE_KEY="AAA.KEY1.KEY2"




### supabase

